{
    "name": "laratoolkit/laravel-translator",
    "description": "Auto-translate Laravel lang/ files and Voyager CMS content using Gemini AI or Google Translate. Web UI included. Supports 15 languages.",
    "keywords": ["laravel", "voyager", "translation", "gemini", "google-translate", "i18n", "localization"],
    "license": "MIT",
    "authors": [
        {
            "name": "Samet Kuku",
            "email": "zsamet996@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "illuminate/support": ">=9.0",
        "illuminate/console": ">=9.0",
        "illuminate/database": ">=9.0",
        "illuminate/http": ">=9.0",
        "illuminate/routing": ">=9.0"
    },
    "autoload": {
        "psr-4": {
            "SametKuku\\LaravelTranslator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SametKuku\\LaravelTranslator\\LaravelTranslatorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
